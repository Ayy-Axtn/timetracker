{
  "name": "timetracker",
  "version": "1.0.0",
  "description": "Local Windows tray app for personal time tracking, triggered by a Stream Deck via a custom protocol handler.",
  "author": "Ayy-Axtn",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "gen:icons": "node scripts/gen-icons.mjs",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "db:selftest": "npm run build && node scripts/db-selftest.mjs",
    "triggers:selftest": "npm run build && node scripts/triggers-selftest.mjs",
    "triggers:e2e": "npm run build && node scripts/triggers-e2e.mjs",
    "state:selftest": "npm run build && node scripts/state-selftest.mjs",
    "state:integration": "npm run build && node scripts/state-integration.mjs",
    "popup:e2e": "npm run build && node scripts/popup-e2e.mjs",
    "log:selftest": "npm run build && node scripts/log-selftest.mjs",
    "log:e2e": "npm run build && node scripts/log-e2e.mjs",
    "config:selftest": "npm run build && node scripts/config-selftest.mjs",
    "settings:e2e": "npm run build && node scripts/settings-e2e.mjs",
    "rebuild": "electron-rebuild --force --only better-sqlite3",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "electron-builder": "^26.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.7.1",
    "electron-vite": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
